pipeline {
    agent any

    tools {
        jdk 'jdk11'
        maven 'maven3'
    }

    environment {
        SCANNER_HOME = tool 'sonar-scanner'
        JAVA_HOME = '/usr/lib/jvm/java-17-openjdk-amd64'
        PATH = "${JAVA_HOME}/bin:${env.PATH}"
    }

    stages {

        stage("Git Checkout") {
            steps {
                git branch: 'main',
                    url: 'https://github.com/aravindc1432-hash/Ekart.git'
            }
        }

        stage("Compile") {
            steps {
                sh "mvn clean compile"
            }
        }
        
        stage("Test-Jacoco") {
            steps {
                sh "mvn clean verify"
            }
        } 

        stage("SonarQube Analysis") {
            steps {
                withSonarQubeEnv('sonar-server') {
                    sh """
                    ${SCANNER_HOME}/bin/sonar-scanner \
                    -Dsonar.projectName=Ekart \
                    -Dsonar.projectKey=Ekart \
                    -Dsonar.sources=src/main/java \
                    -Dsonar.tests=src/test/java \
                    -Dsonar.java.binaries=target/classes \
                    -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml \
                    -Dsonar.exclusions=target/**,bin/**,dockerfile,pom.xml
                    """
                }
            }
        }
        
        stage("OWASP Dependency Check") {
            steps {
                dependencyCheck(
                    additionalArguments: '''--scan target/ --format XML --format HTML --out . --disableAssembly''',
                    odcInstallation: 'owasp'
                )

                dependencyCheckPublisher pattern: 'dependency-check-report.xml'
            }
        }
        
        stage("Build") {
            steps {
                sh "mvn clean package -DskipTests=true"
            }
        }

        stage("Build Docker Image") {
            steps {
                script {
                    withDockerRegistry(credentialsId: 'docker-cred') {
                        sh "docker build -t ekart -f dockerfile/Dockerfile ."
                        sh "docker tag ekart reddy177/ekart:latest"
                        sh "docker push reddy177/ekart:latest"
                    }
                }
            }
        }

        stage("Contanirization of Application") {
            steps {
                script {
                    sh "docker run -d --name ekart -p 8070:8070 reddy177/ekart:latest"
                }
            }
        }
    }

    post {
        success {
            echo "Pipeline executed successfully"
        }

        failure {
            echo "Pipeline failed"
        }
    }
}
